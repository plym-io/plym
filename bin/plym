#!/bin/sh
set -e

REPO_OWNER="${PLYM_TEMPLATE_REPO_OWNER:-plym-io}"
REPO_NAME="${PLYM_TEMPLATE_REPO_NAME:-plym-templates}"
HEALTH_TIMEOUT_SECONDS="${PLYM_HEALTH_TIMEOUT_SECONDS:-60}"
INSTALL_URL="${PLYM_INSTALL_URL:-https://raw.githubusercontent.com/plym-io/plym/main/install.sh}"
VERBOSE="${PLYM_VERBOSE:-0}"

PLYM_HOME="${PLYM_CONFIG_HOME:-$HOME/.config/plym}"
ACTIVE_FILE="$PLYM_HOME/active"

# Load the shared helper library: colors, say/note/warn/fail, box, spin, retry, http,
# wait_for_health, port_in_use, fetch_admin and the docker-compose introspection helpers.
# It lives next to this script; both files are installed together.
_self="$0"
[ -L "$_self" ] && _self=$(readlink -f "$_self" 2>/dev/null || python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "$_self")
_LIBDIR=$(CDPATH= cd -- "$(dirname -- "$_self")" 2>/dev/null && pwd)
if [ -r "$_LIBDIR/plym-lib.sh" ]; then
    . "$_LIBDIR/plym-lib.sh"
else
    printf '\033[38;5;208m✗\033[0m plym-lib.sh is missing next to %s — the plym install is incomplete.\n' "$_self" >&2
    printf '  Copy both files together: cp <plym-checkout>/bin/plym <plym-checkout>/bin/plym-lib.sh "%s"/\n' "$_LIBDIR" >&2
    exit 1
fi

abspath() {
    if readlink -f "$1" >/dev/null 2>&1; then
        readlink -f "$1"
    else
        python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "$1"
    fi
}

is_plym_dir() {
    [ -f "$1/docker-compose.yml" ] && grep -q 'io\.plym\.instance' "$1/docker-compose.yml" 2>/dev/null
}

instance_port() {
    p=$(grep '^PLYM_PORT=' "$1/.env" 2>/dev/null | cut -d= -f2- | head -1)
    printf '%s' "${p:-9173}"
}

list_instances() {
    docker ps -a --filter label=io.plym.instance \
        --format '{{.Label "com.docker.compose.project.working_dir"}}	{{.Label "com.docker.compose.project"}}	{{.State}}' \
        2>/dev/null | awk 'NF' | sort -u
}

find_project_upward() {
    d=$(pwd)
    while [ "$d" != "/" ]; do
        if is_plym_dir "$d"; then printf '%s\n' "$d"; return 0; fi
        d=$(dirname "$d")
    done
    return 1
}

resolve_project() {
    RESOLVED=""
    if [ -n "$OPT_PROJECT" ]; then
        is_plym_dir "$OPT_PROJECT" || fail "Not a plym project: $OPT_PROJECT"
        RESOLVED=$(abspath "$OPT_PROJECT"); return 0
    fi
    if [ -n "$PLYM_DIR" ]; then
        is_plym_dir "$PLYM_DIR" || fail "PLYM_DIR is not a plym project: $PLYM_DIR"
        RESOLVED=$(abspath "$PLYM_DIR"); return 0
    fi
    if up=$(find_project_upward); then RESOLVED="$up"; return 0; fi
    if [ -f "$ACTIVE_FILE" ]; then
        a=$(cat "$ACTIVE_FILE")
        if is_plym_dir "$a"; then RESOLVED="$a"; return 0; fi
    fi
    dirs=$(list_instances | cut -f1 | awk 'NF')
    count=$(printf '%s\n' "$dirs" | awk 'NF' | wc -l | tr -d ' ')
    if [ "$count" = "1" ]; then RESOLVED="$dirs"; return 0; fi
    [ "$count" = "0" ] && fail "No plym instance found. Run from inside a blog directory, set PLYM_DIR, or pass -C <dir>."
    fail "Multiple blogs and none active. Pick one with 'plym use <name>' (or pass -C <dir>):

$(cmd_list)"
}

enter_project() {
    resolve_project
    cd "$RESOLVED"
    PROJECT_ROOT="$RESOLVED"
    PORT=$(instance_port "$RESOLVED")
    BASE_URL="http://localhost:$PORT"
    PROJECT_LABEL=$(grep '^COMPOSE_PROJECT_NAME=' .env 2>/dev/null | cut -d= -f2- | head -1)
    [ -n "$PROJECT_LABEL" ] || PROJECT_LABEL=$(basename "$PROJECT_ROOT")
    # Admin bundle lives in a bind-mounted dir (not baked into the image), so a failed fetch can
    # reuse the previous one. Ensure it exists and is owned by us before any `docker compose up`.
    ADMIN_DIR="$PROJECT_ROOT/admin"
    ADMIN_VERSION=$(grep '^PLYM_ADMIN_VERSION=' .env 2>/dev/null | cut -d= -f2- | head -1)
    mkdir -p "$ADMIN_DIR"
}

usage() {
    cat <<EOF
Usage:
  plym list                            Show every blog on this machine (active one in green).
  plym use <name|dir>                  Set the active blog for commands run outside a blog dir.
  plym set url <url> --<proxy>         Serve the active blog on your own domain through a reverse
                                       proxy. <url> is a domain, subdomain, or domain/path, e.g.
                                       blog.flapico.com or flapico.com/blog.
                                       Proxies: --nginx, --caddy, --traefik.
  plym unset url                       Remove the reverse proxy config plym created.
  plym template install <name> [ref]   Switch to a template. Uses the local copy in plym/templates/
                                       if present, else downloads it. Pass --update to force a fresh
                                       download. Default ref: main. Refs are a branch, tag, or SHA.
  plym admin update                    Refetch the admin bundle into ./admin and restart the api. If the
                                       fetch fails the existing admin bundle is kept (never removed).
  plym update                          Pull the latest plym, rebuild the api image, refetch the admin
                                       bundle, reload caddy, and re-render. Updates the whole stack.
  plym reinstall [--yes]               Wipe the stack AND its database volume, then reinstall from
                                       source. Destructive: deletes all posts, regenerates the admin
                                       password. Asks for confirmation unless --yes.
  plym reload                          Restart the api to apply config.yaml. No re-render — use for
                                       runtime-only changes (http_cache, pagination, robots, media).
  plym rebuild                         Restart the api and re-render every published post. Use when a
                                       change affects rendered HTML (template, prism, reading, logo).

Global options (accepted before the command, e.g. plym --verbose update):
  -v, --verbose                       Stream every underlying log live — docker build/compose, the api
                                      container logs, HTTP requests/responses, and proxy reloads.
                                      Errors and full tracebacks are shown either way; --verbose adds
                                      the live stream. Same as PLYM_VERBOSE=1.
  -C <dir>, --project <dir>           Operate on the blog in <dir> (also PLYM_DIR=<dir>).
  Otherwise: the current blog dir if you are inside one, else the active blog,
  else the sole blog if there is only one.

Environment overrides:
  PLYM_TEMPLATE_REPO_OWNER (default: plym-io)
  PLYM_TEMPLATE_REPO_NAME  (default: plym-templates)
  PLYM_HEALTH_TIMEOUT_SECONDS (default: 60)
  PLYM_VERBOSE=1           Same as --verbose.
EOF
}

load_creds() {
    [ -f .env ] || fail ".env not found in $PROJECT_ROOT"
    EMAIL=$(grep '^PLYM_SUPERUSER_EMAIL=' .env | cut -d= -f2- | head -1)
    PASSWORD=$(grep '^PLYM_SUPERUSER_PASSWORD=' .env | cut -d= -f2- | head -1)
    [ -n "$EMAIL" ] && [ -n "$PASSWORD" ] || \
        fail "Could not read PLYM_SUPERUSER_EMAIL/PASSWORD from .env"
}

attempt_login() {
    http POST "$BASE_URL/api/auth/login" \
        -H 'Content-Type: application/json' \
        -d "{\"email\":\"$EMAIL\",\"password\":\"$PASSWORD\"}" || return 1
    TOKEN=$(printf '%s' "$HTTP_BODY" | grep -o '"access_token":"[^"]*"' | sed 's/^"access_token":"//;s/"$//')
    [ -n "$TOKEN" ]
}

login() {
    load_creds
    retry 5 attempt_login && return 0
    # Every attempt failed. Show what actually came back — the HTTP status and body, or the raw
    # transport error (e.g. curl 56 when the worker died mid-request) — plus the api container's
    # state and logs, so the real reason is visible instead of a bare "Login failed".
    printf 'Login failed for %s after 5 attempts.\n' "$EMAIL"
    printf 'Last response: HTTP %s\n' "$HTTP_CODE"
    [ -n "$HTTP_BODY" ] && printf '%s\n' "$HTTP_BODY"
    printf '\n'
    dump_service api
    dump_unhealthy
    return 1
}

refresh_all_posts() {
    login || return 1
    ids=""
    page=1
    while :; do
        http GET "$BASE_URL/api/posts?include_drafts=true&page=$page&page_size=200" \
            -H "Authorization: Bearer $TOKEN" || {
                printf 'Could not list posts to re-render (page %s, HTTP %s):\n%s\n' "$page" "$HTTP_CODE" "$HTTP_BODY"
                return 1
            }
        page_ids=$(printf '%s' "$HTTP_BODY" | python3 -c "import sys,json;print(' '.join(str(p['id']) for p in json.load(sys.stdin)['items']))" 2>/dev/null)
        [ -n "$page_ids" ] || break
        ids="$ids $page_ids"
        count=$(printf '%s' "$page_ids" | wc -w | tr -d ' ')
        [ "$count" -lt 200 ] && break
        page=$((page + 1))
    done
    for id in $ids; do
        http POST "$BASE_URL/api/posts/$id/refresh" -H "Authorization: Bearer $TOKEN" >/dev/null || {
            printf 'Re-render failed for post %s (HTTP %s):\n%s\n' "$id" "$HTTP_CODE" "$HTTP_BODY"
            return 1
        }
    done
    return 0
}

# (re)start the api so it picks up mounted code, config.yaml and the admin bundle, then health-gate.
# `up -d` first guarantees the whole stack (db/caddy/api) is running and recreates api/caddy when
# their image or env changed; the explicit restart re-reads the bind mounts without an image build.
restart_api() {
    docker compose up -d
    docker compose restart api
    wait_for_health
}

restart_caddy() {
    docker compose restart caddy
    wait_for_health
}

# apply [--build] [--admin] [--caddy] [--render] — bring the stack into line after a change.
# Each step is spinned (so it streams under --verbose and boxes its output on failure); the api
# is always restarted and health-gated. This single pipeline replaces the per-command sequences.
apply() {
    _build=0; _admin=0; _caddy=0; _render=0
    for _f in "$@"; do
        case "$_f" in
            --build)  _build=1 ;;
            --admin)  _admin=1 ;;
            --caddy)  _caddy=1 ;;
            --render) _render=1 ;;
        esac
    done
    if [ "$_admin" = 1 ]; then spin "Fetching admin bundle ($ADMIN_VERSION)" fetch_admin "$ADMIN_VERSION" "$ADMIN_DIR" || return 1; fi
    if [ "$_build" = 1 ]; then spin "Rebuilding api image" docker compose build api || return 1; fi
    spin "Restarting api" restart_api || return 1
    if [ "$_caddy" = 1 ]; then spin "Reloading caddy" restart_caddy || return 1; fi
    if [ "$_render" = 1 ]; then spin "Re-rendering published posts" refresh_all_posts || return 1; fi
    return 0
}

normalize_prefix() {
    p="$1"
    while [ "${p%/}" != "$p" ]; do p="${p%/}"; done
    case "$p" in ""|/*) ;; *) p="/$p" ;; esac
    printf '%s' "$p"
}

warn_prefix_drift() {
    cfg=$(normalize_prefix "$(grep '^blog_prefix:' config.yaml 2>/dev/null | awk '{print $2}')")
    cfg="${cfg:-/blog}"
    env=$(normalize_prefix "$(grep '^PLYM_BLOG_PREFIX=' .env 2>/dev/null | cut -d= -f2- | head -1)")
    env="${env:-/blog}"
    [ "$cfg" = "$env" ] && return 0
    note "blog_prefix drift: config.yaml says '$cfg' but caddy is serving '$env'."
    note "Routing won't change until both match. Run: plym set url <your-url>$cfg"
}

template_exists_local() {
    [ -d "plym/templates/$1" ]
}

set_active_template() {
    name="$1"
    if grep -q '^template:' config.yaml; then
        sed -i.bak "s|^template: .*|template: $name|" config.yaml
        rm -f config.yaml.bak
    else
        printf "template: %s\n" "$name" >> config.yaml
    fi
}

fetch_template_remote() {
    name="$1"; ref="$2"
    target="plym/templates/$name"
    tmp=$(mktemp -d)
    url="https://codeload.github.com/$REPO_OWNER/$REPO_NAME/tar.gz/$ref"
    if ! curl -fsSL "$url" \
        | tar -xz -C "$tmp" --strip-components=2 "$REPO_NAME-$ref/templates/$name" 2>/dev/null \
        || [ ! -d "$tmp/$name" ]; then
        rm -rf "$tmp"
        echo "Template '$name' not found in $REPO_OWNER/$REPO_NAME@$ref" >&2
        return 1
    fi
    rm -rf "$target"
    mv "$tmp/$name" "$target"
    rm -rf "$tmp"
}

DOCS_URL="https://plym.io/docs/reverse-proxy"

PROXY_HEADERS='        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;'

set_env_key() {
    if grep -q "^$1=" .env 2>/dev/null; then
        sed -i.bak "s|^$1=.*|$1=$2|" .env && rm -f .env.bak
    else
        printf '%s=%s\n' "$1" "$2" >> .env
    fi
}

unset_env_key() {
    sed -i.bak "/^$1=/d" .env && rm -f .env.bak
}

set_config_key() {
    if grep -q "^$1:" config.yaml 2>/dev/null; then
        sed -i.bak "s|^$1: .*|$1: $2|" config.yaml && rm -f config.yaml.bak
    else
        printf '%s: %s\n' "$1" "$2" >> config.yaml
    fi
}

pkg_install() {
    _q="-qq"; [ "$VERBOSE" = "1" ] && _q=""
    if command -v apt-get >/dev/null 2>&1; then
        $SUDO apt-get update $_q && $SUDO apt-get install -y $_q "$@"
    elif command -v dnf >/dev/null 2>&1; then
        $SUDO dnf install -y "$@"
    elif command -v yum >/dev/null 2>&1; then
        $SUDO yum install -y "$@"
    elif command -v pacman >/dev/null 2>&1; then
        $SUDO pacman -S --noconfirm "$@"
    elif command -v zypper >/dev/null 2>&1; then
        $SUDO zypper install -y "$@"
    elif command -v apk >/dev/null 2>&1; then
        $SUDO apk add "$@"
    elif command -v brew >/dev/null 2>&1; then
        brew install "$@"
    else
        return 1
    fi
}

dns_preflight() {
    server_ip=$(curl -fsS --max-time 5 https://api.ipify.org 2>/dev/null) || server_ip=""
    host_ip=$(python3 -c "import socket,sys;print(socket.gethostbyname(sys.argv[1]))" "$HOST" 2>/dev/null) || host_ip=""
    if [ -z "$host_ip" ]; then
        fail "$HOST does not resolve yet. Add an A record for $HOST -> ${server_ip:-this server}, wait for DNS to propagate, then re-run."
    fi
    if [ -z "$server_ip" ]; then
        note "Could not determine this machine's public IP — skipping the DNS check."
        return 0
    fi
    if [ "$host_ip" != "$server_ip" ]; then
        fail "$HOST resolves to $host_ip but this machine is $server_ip. Point the A record at $server_ip and re-run."
    fi
}

proxy_locations() {
    max_body=$(grep '^PLYM_UPLOAD_MAX_BYTES=' .env 2>/dev/null | cut -d= -f2- | head -1)
    max_body="${max_body:-10485760}"
    if [ -n "$URL_PATH" ]; then
        cat <<EOF
    location = $URL_PATH {
        client_max_body_size $max_body;
        proxy_pass http://127.0.0.1:$PORT;
$PROXY_HEADERS
    }

    location $URL_PATH/ {
        client_max_body_size $max_body;
        proxy_pass http://127.0.0.1:$PORT;
$PROXY_HEADERS
    }
EOF
    else
        cat <<EOF
    location / {
        client_max_body_size $max_body;
        proxy_pass http://127.0.0.1:$PORT;
$PROXY_HEADERS
    }
EOF
    fi
}

nginx_vhost() {
    locations=$(proxy_locations)
    cat <<EOF
server {
    listen 80;
    listen [::]:80;
    server_name $HOST;

$locations
}
EOF
}

nginx_has_domain() {
    $SUDO nginx -T 2>/dev/null \
        | awk '$1 == "server_name" {for (i = 2; i <= NF; i++) {gsub(";", "", $i); print $i}}' \
        | grep -Fxq "$HOST"
}

nginx_conf_target() {
    if [ -d /etc/nginx/sites-available ]; then
        NGINX_CONF="/etc/nginx/sites-available/plym-$HOST.conf"
        NGINX_LINK="/etc/nginx/sites-enabled/plym-$HOST.conf"
    elif [ -d /etc/nginx/conf.d ]; then
        NGINX_CONF="/etc/nginx/conf.d/plym-$HOST.conf"
        NGINX_LINK=""
    elif command -v brew >/dev/null 2>&1 && [ -d "$(brew --prefix 2>/dev/null)/etc/nginx/servers" ]; then
        NGINX_CONF="$(brew --prefix)/etc/nginx/servers/plym-$HOST.conf"
        NGINX_LINK=""
    else
        fail "Could not find an nginx config directory (looked for sites-available and conf.d)."
    fi
}

reload_nginx() {
    $SUDO nginx -t >/dev/null 2>&1 || return 1
    $SUDO systemctl reload nginx 2>/dev/null || $SUDO nginx -s reload
}

certbot_has_nginx_plugin() {
    $SUDO certbot plugins 2>/dev/null | grep -q '\* nginx'
}

run_certbot() {
    EMAIL=$(grep '^PLYM_SUPERUSER_EMAIL=' .env 2>/dev/null | cut -d= -f2- | head -1)
    case "$EMAIL" in
        *@*.local|"") email_args="--register-unsafely-without-email" ;;
        *) email_args="-m $EMAIL" ;;
    esac
    $SUDO certbot --nginx -d "$HOST" --non-interactive --agree-tos --redirect $email_args
}

setup_nginx() {
    if ! command -v nginx >/dev/null 2>&1; then
        if port_in_use 80 || port_in_use 443; then
            fail "nginx isn't installed but something else is listening on 80/443. Free those ports or configure that proxy yourself: $DOCS_URL"
        fi
        spin "Installing nginx" pkg_install nginx || fail "Could not install nginx. Install it yourself, then re-run."
        $SUDO systemctl enable --now nginx >/dev/null 2>&1 || true
    fi
    dns_preflight
    OUR_CONF=""
    for c in "/etc/nginx/sites-available/plym-$HOST.conf" "/etc/nginx/conf.d/plym-$HOST.conf"; do
        [ -f "$c" ] && OUR_CONF="$c"
    done
    if [ -z "$OUR_CONF" ] && nginx_has_domain; then
        deleg_dir="/etc/nginx/plym/$HOST"
        deleg_file="$deleg_dir/$PROJECT_LABEL.conf"
        $SUDO mkdir -p "$deleg_dir"
        proxy_locations | $SUDO tee "$deleg_file" >/dev/null
        if $SUDO nginx -T 2>/dev/null | grep -q "plym/$HOST"; then
            spin "Reloading nginx" reload_nginx || fail "nginx config test failed (nginx -t has details)."
            say "Route added to your existing $HOST server block."
        else
            say "Wrote $deleg_file"
            note "$HOST is already configured in your nginx, so plym won't touch that server block."
            printf "  Add this line inside your existing %sserver { }%s for %s, then reload nginx:\n\n" "$BOLD" "$RESET" "$HOST"
            printf "    %sinclude /etc/nginx/plym/%s/*.conf;%s\n\n" "$BOLD" "$HOST" "$RESET"
            note "Every future plym blog on $HOST will then work with no manual steps."
        fi
        return 0
    fi
    nginx_conf_target
    nginx_vhost | $SUDO tee "$NGINX_CONF" >/dev/null
    [ -n "$NGINX_LINK" ] && $SUDO ln -sf "$NGINX_CONF" "$NGINX_LINK"
    if ! $SUDO nginx -t >/dev/null 2>&1; then
        $SUDO rm -f "$NGINX_CONF" "$NGINX_LINK"
        fail "Generated vhost failed nginx -t — removed it again, your nginx is untouched. Run '$SUDO nginx -t' for details."
    fi
    spin "Reloading nginx" reload_nginx
    if ! command -v certbot >/dev/null 2>&1; then
        spin "Installing certbot" pkg_install certbot python3-certbot-nginx \
            || spin "Installing certbot" pkg_install certbot certbot-nginx \
            || spin "Installing certbot" pkg_install certbot \
            || true
    fi
    if command -v certbot >/dev/null 2>&1 && ! certbot_has_nginx_plugin; then
        spin "Installing the certbot nginx plugin" pkg_install python3-certbot-nginx \
            || spin "Installing the certbot nginx plugin" pkg_install certbot-nginx \
            || true
    fi
    if command -v certbot >/dev/null 2>&1 && certbot_has_nginx_plugin; then
        spin "Obtaining TLS certificate for $HOST" run_certbot \
            || note "certbot failed — $HOST works over HTTP. Fix DNS/firewall and run: $SUDO certbot --nginx -d $HOST"
    else
        note "certbot's nginx plugin is missing — $HOST works over HTTP. For HTTPS install python3-certbot-nginx, then run: $SUDO certbot --nginx -d $HOST"
    fi
}

caddy_site() {
    if [ -n "$URL_PATH" ]; then
        cat <<EOF
$HOST {
	handle $URL_PATH {
		reverse_proxy 127.0.0.1:$PORT
	}

	handle $URL_PATH/* {
		reverse_proxy 127.0.0.1:$PORT
	}
}
EOF
    else
        cat <<EOF
$HOST {
	reverse_proxy 127.0.0.1:$PORT
}
EOF
    fi
}

install_caddy() {
    if command -v apt-get >/dev/null 2>&1; then
        $SUDO apt-get install -y -qq debian-keyring debian-archive-keyring apt-transport-https >/dev/null 2>&1 || true
        curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' \
            | $SUDO gpg --dearmor --yes -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
        curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' \
            | $SUDO tee /etc/apt/sources.list.d/caddy-stable.list >/dev/null
        _q="-qq"; [ "$VERBOSE" = "1" ] && _q=""
        $SUDO apt-get update $_q && $SUDO apt-get install -y $_q caddy
    else
        pkg_install caddy
    fi
}

reload_caddy() {
    $SUDO systemctl reload caddy 2>/dev/null \
        || $SUDO caddy reload --config /etc/caddy/Caddyfile
}

setup_caddy() {
    if ! command -v caddy >/dev/null 2>&1; then
        if port_in_use 80 || port_in_use 443; then
            fail "caddy isn't installed but something else is listening on 80/443. Free those ports or configure that proxy yourself: $DOCS_URL"
        fi
        spin "Installing caddy" install_caddy || fail "Could not install caddy (https://caddyserver.com/docs/install). Install it yourself, then re-run."
        $SUDO systemctl enable --now caddy >/dev/null 2>&1 || true
    fi
    dns_preflight
    main_caddyfile="/etc/caddy/Caddyfile"
    site_file="/etc/caddy/plym/$HOST.caddy"
    if [ -f "$main_caddyfile" ] && grep -Eq "^$HOST([[:space:],{]|$)" "$main_caddyfile" 2>/dev/null; then
        say "$HOST is already configured in your Caddyfile — plym won't touch that site block."
        printf "  Add these routes inside your existing %s%s { }%s block, then reload caddy:\n\n" "$BOLD" "$HOST" "$RESET"
        caddy_site | sed '1d;$d'
        printf "\n"
        return 0
    fi
    $SUDO mkdir -p /etc/caddy/plym
    caddy_site | $SUDO tee "$site_file" >/dev/null
    if ! grep -q "import /etc/caddy/plym/\*.caddy" "$main_caddyfile" 2>/dev/null; then
        printf '\nimport /etc/caddy/plym/*.caddy\n' | $SUDO tee -a "$main_caddyfile" >/dev/null
    fi
    if ! $SUDO caddy validate --config "$main_caddyfile" >/dev/null 2>&1; then
        $SUDO rm -f "$site_file"
        fail "Generated site failed caddy validate — removed it again, your caddy is untouched."
    fi
    spin "Reloading caddy" reload_caddy
    note "Caddy fetches and renews the TLS certificate for $HOST automatically."
}

setup_traefik() {
    rule="Host(\`$HOST\`)"
    [ -n "$URL_PATH" ] && rule="Host(\`$HOST\`) && PathPrefix(\`$URL_PATH\`)"
    cat > docker-compose.traefik.yml <<EOF
services:
  caddy:
    labels:
      traefik.enable: "true"
      traefik.http.routers.$PROJECT_LABEL.rule: $rule
      traefik.http.routers.$PROJECT_LABEL.entrypoints: websecure
      traefik.http.routers.$PROJECT_LABEL.tls.certresolver: letsencrypt
      traefik.http.services.$PROJECT_LABEL.loadbalancer.server.port: "80"
EOF
    say "Wrote docker-compose.traefik.yml"
    note "Traefik setups vary, so finish these three steps yourself:"
    printf "    1. Edit %sentrypoints%s and %scertresolver%s in docker-compose.traefik.yml to match your traefik.\n" "$BOLD" "$RESET" "$BOLD" "$RESET"
    printf "    2. Make sure traefik shares a docker network with this project (or watches the docker socket).\n"
    printf "    3. Run: %sCOMPOSE_FILE=docker-compose.yml:docker-compose.traefik.yml docker compose up -d%s\n" "$BOLD" "$RESET"
    note "More: $DOCS_URL"
}

cmd_set_url() {
    URL_ARG=""
    PROXY=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --nginx)   PROXY=nginx; shift ;;
            --caddy)   PROXY=caddy; shift ;;
            --traefik) PROXY=traefik; shift ;;
            -*) fail "Unknown option: $1" ;;
            *) URL_ARG="$1"; shift ;;
        esac
    done
    [ -n "$URL_ARG" ] || { usage; exit 1; }
    [ -n "$PROXY" ] || fail "Pick a reverse proxy: --nginx, --caddy or --traefik.
  Using a CDN or something else? $DOCS_URL"

    enter_project

    stripped=$(printf '%s' "$URL_ARG" | sed 's|^https\{0,1\}://||; s|/\{1,\}$||')
    HOST=${stripped%%/*}
    URL_PATH=""
    case "$stripped" in
        */*) URL_PATH="/${stripped#*/}" ;;
    esac
    [ -n "$HOST" ] || fail "Could not parse a domain from '$URL_ARG'."
    case "$HOST" in
        *:*) fail "Drop the port — plym serves $HOST through the proxy on 80/443." ;;
    esac

    PUBLIC_URL="$HOST$URL_PATH"
    case "$PROXY" in
        nginx)   plan="install nginx if missing, write an nginx config for $HOST, reload nginx, obtain a TLS certificate via certbot" ;;
        caddy)   plan="install caddy if missing, write a caddy site for $HOST, reload caddy (TLS is automatic)" ;;
        traefik) plan="write docker-compose.traefik.yml with router labels for you to finish (no sudo)" ;;
    esac
    note "plym will: $plan."
    if [ -e /dev/tty ]; then
        printf "%s%s%s → %s%s%s  proceed? %s[Y/n]%s " \
            "$BOLD" "$PUBLIC_URL" "$RESET" "$GREEN" "$PROJECT_LABEL" "$RESET" "$DIM" "$RESET" > /dev/tty
        read confirm < /dev/tty || true
        case "$confirm" in n|N|no|NO) fail "Cancelled." ;; esac
    fi

    SUDO=""
    if [ "$PROXY" != "traefik" ] && [ "$(id -u)" != 0 ]; then
        SUDO="sudo"
        sudo -v || fail "sudo is required to configure $PROXY. Prefer no sudo? $DOCS_URL"
    fi

    if [ -n "$URL_PATH" ]; then
        set_config_key blog_prefix "$URL_PATH"
        set_env_key PLYM_BLOG_PREFIX "$URL_PATH"
        BLOG_PREFIX="$URL_PATH"
    else
        BLOG_PREFIX=$(grep '^blog_prefix:' config.yaml 2>/dev/null | awk '{print $2}')
        BLOG_PREFIX="${BLOG_PREFIX:-/blog}"
    fi
    set_config_key website "$HOST"
    set_config_key blog_home "$HOST$BLOG_PREFIX"
    set_env_key PLYM_PUBLIC_URL "$PUBLIC_URL"
    set_env_key PLYM_PROXY "$PROXY"

    setup_$PROXY

    apply --render

    printf "\n  %s%s%s now serves %s%s%s\n" "$GREEN" "$PUBLIC_URL" "$RESET" "$BOLD" "$PROJECT_LABEL" "$RESET"
    note "  Admin: https://$HOST$BLOG_PREFIX/plym-admin"
    note "  Undo anytime with 'plym unset url'."
    printf "\n"
}

cmd_unset_url() {
    enter_project
    PUBLIC_URL=$(grep '^PLYM_PUBLIC_URL=' .env 2>/dev/null | cut -d= -f2- | head -1)
    PROXY=$(grep '^PLYM_PROXY=' .env 2>/dev/null | cut -d= -f2- | head -1)
    [ -n "$PUBLIC_URL" ] || fail "No public URL is set for $PROJECT_LABEL."
    HOST=${PUBLIC_URL%%/*}
    SUDO=""
    [ "$PROXY" != "traefik" ] && [ "$(id -u)" != 0 ] && SUDO="sudo"
    case "$PROXY" in
        nginx)
            $SUDO rm -f "/etc/nginx/sites-available/plym-$HOST.conf" \
                        "/etc/nginx/sites-enabled/plym-$HOST.conf" \
                        "/etc/nginx/conf.d/plym-$HOST.conf" \
                        "/etc/nginx/plym/$HOST/$PROJECT_LABEL.conf"
            $SUDO rmdir "/etc/nginx/plym/$HOST" 2>/dev/null || true
            spin "Reloading nginx" reload_nginx || true
            ;;
        caddy)
            $SUDO rm -f "/etc/caddy/plym/$HOST.caddy"
            spin "Reloading caddy" reload_caddy || true
            ;;
        traefik)
            rm -f docker-compose.traefik.yml
            note "If COMPOSE_FILE references docker-compose.traefik.yml, remove it and run 'docker compose up -d'."
            ;;
    esac
    unset_env_key PLYM_PUBLIC_URL
    unset_env_key PLYM_PROXY
    say "$PUBLIC_URL removed from $PROXY. The blog still runs on :$PORT."
}

cmd_list() {
    active=""
    [ -f "$ACTIVE_FILE" ] && active=$(cat "$ACTIVE_FILE")
    rows=$(list_instances)
    if [ -z "$rows" ]; then
        note "No plym blogs found."
        return
    fi
    printf "%s%-16s %-6s %-9s %s%s\n" "$DIM" "NAME" "PORT" "STATUS" "DIR" "$RESET"
    printf '%s\n' "$rows" | while IFS='	' read -r dir project state; do
        [ -n "$dir" ] || continue
        field=$(printf '%-16s' "$project")
        [ "$dir" = "$active" ] && field="${GREEN}${field}${RESET}"
        printf "%s %-6s %-9s %s\n" "$field" "$(instance_port "$dir")" "$state" "$dir"
    done
}

cmd_use() {
    target="$1"
    [ -n "$target" ] || { usage; exit 1; }
    match=""
    rows=$(list_instances)
    if [ -n "$rows" ]; then
        match=$(printf '%s\n' "$rows" | while IFS='	' read -r dir project state; do
            [ -n "$dir" ] || continue
            if [ "$project" = "$target" ] || [ "$dir" = "$target" ] || [ "$(basename "$dir")" = "$target" ]; then
                printf '%s\n' "$dir"; break
            fi
        done)
    fi
    if [ -z "$match" ] && is_plym_dir "$target"; then
        match=$(abspath "$target")
    fi
    [ -n "$match" ] || fail "No plym blog matching '$target'. See 'plym list'."
    mkdir -p "$PLYM_HOME"
    printf '%s\n' "$match" > "$ACTIVE_FILE"
    printf "%s→%s %s%s%s now active %s(:%s)%s\n" \
        "$ACCENT" "$RESET" "$GREEN" "$(basename "$match")" "$RESET" \
        "$DIM" "$(instance_port "$match")" "$RESET"
}

cmd_template_install() {
    enter_project
    update=""
    name=""
    ref=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --update|-u) update=1 ;;
            -*) fail "Unknown option: $1" ;;
            *)
                if [ -z "$name" ]; then name="$1"
                elif [ -z "$ref" ]; then ref="$1"
                fi ;;
        esac
        shift
    done
    ref="${ref:-main}"
    [ -n "$name" ] || { usage; exit 1; }

    note "Installing template '$name' into $PROJECT_LABEL"
    if [ -z "$update" ] && template_exists_local "$name"; then
        note "Using local template (pass --update to fetch the latest from $REPO_OWNER/$REPO_NAME)"
    else
        spin "Downloading $name from $REPO_OWNER/$REPO_NAME@$ref" fetch_template_remote "$name" "$ref"
    fi
    set_active_template "$name"
    apply --render
    say "Template '$name' is live."
}

cmd_reload() {
    enter_project
    note "Reloading $PROJECT_LABEL config (:$PORT)"
    apply
    warn_prefix_drift
    say "Config reloaded."
}

cmd_rebuild() {
    enter_project
    note "Rebuilding $PROJECT_LABEL (:$PORT)"
    apply --render
    warn_prefix_drift
    say "Rebuild complete."
}

sync_cli() {
    installed=$(command -v plym 2>/dev/null) || return 0
    [ -n "$installed" ] && [ "$installed" != "$PROJECT_ROOT/bin/plym" ] || return 0
    dir=$(dirname "$installed")
    if [ ! -w "$dir" ]; then
        note "CLI at $installed isn't writable — refresh it with: cp $PROJECT_ROOT/bin/plym $PROJECT_ROOT/bin/plym-lib.sh $dir/"
        return 0
    fi
    # The CLI is two files (plym + plym-lib.sh); keep them in lockstep so a refreshed plym never
    # sources a stale lib.
    for f in plym plym-lib.sh; do
        tmp=$(mktemp "$dir/.plym.XXXXXX" 2>/dev/null) || return 0
        if cp "$PROJECT_ROOT/bin/$f" "$tmp" && chmod +x "$tmp"; then
            mv -f "$tmp" "$dir/$f"
        else
            rm -f "$tmp"
        fi
    done
}

cmd_admin_update() {
    enter_project
    note "Refetching the admin app (${ADMIN_VERSION:-no PLYM_ADMIN_VERSION set}) for $PROJECT_LABEL"
    apply --admin
    say "Admin updated."
}

cmd_update() {
    enter_project
    [ -d .git ] || fail "Not a git checkout — this blog wasn't installed via the plym installer, so there's nothing to pull. Update it the way you deployed it."
    note "Updating $PROJECT_LABEL (:$PORT)"
    before=$(git rev-parse HEAD)
    spin "Pulling latest plym" git pull --ff-only
    after=$(git rev-parse HEAD)
    sync_cli
    apply --build --admin --caddy --render
    warn_prefix_drift
    if [ "$before" = "$after" ]; then
        say "Already on the latest commit — image, admin bundle and renders refreshed."
    else
        say "Updated $(printf '%s' "$before" | cut -c1-7) → $(printf '%s' "$after" | cut -c1-7)."
    fi
}

cmd_reinstall() {
    enter_project
    yes=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --yes|-y) yes=1 ;;
            -*) fail "Unknown option: $1" ;;
        esac
        shift
    done

    name=$(grep '^name:' config.yaml 2>/dev/null | sed 's/^name:[[:space:]]*//')
    email=$(grep '^PLYM_SUPERUSER_EMAIL=' .env 2>/dev/null | cut -d= -f2- | head -1)
    port=$(grep '^PLYM_PORT=' .env 2>/dev/null | cut -d= -f2- | head -1)
    dir=$(basename "$PROJECT_ROOT")
    parent=$(dirname "$PROJECT_ROOT")

    note "Reinstalling $PROJECT_LABEL from source."
    note "This DELETES the database volume (every post) and regenerates the admin password. Back up first if you need the content."
    if [ -z "$yes" ]; then
        [ -e /dev/tty ] || fail "Refusing to reinstall non-interactively. Re-run with: plym reinstall --yes"
        printf "Type the blog name (%s%s%s) to confirm: " "$BOLD" "$name" "$RESET" > /dev/tty
        read confirm < /dev/tty || confirm=""
        [ "$confirm" = "$name" ] || fail "Did not match — aborted."
    fi

    spin "Removing stack and volumes" docker compose down -v
    cd "$parent"
    rm -rf "$dir"
    say "Reinstalling from $INSTALL_URL …"
    export PLYM_DIR="$dir" PLYM_PORT="$port"
    exec sh -c 'curl -fsSL "$1" | sh -s "$2" "$3"' _ "$INSTALL_URL" "$name" "$email"
}

OPT_PROJECT=""
while [ $# -gt 0 ]; do
    case "$1" in
        -C|--project)
            [ -n "$2" ] || fail "$1 requires a directory"
            OPT_PROJECT="$2"; shift 2 ;;
        -v|--verbose)
            VERBOSE=1; export PLYM_VERBOSE=1; shift ;;
        --) shift; break ;;
        *) break ;;
    esac
done

# --verbose is global and may appear anywhere, including AFTER the command (e.g.
# `plym update --verbose`). Strip it from the remaining args, preserving order and spaces, so it
# works for every command — not only the ones that happen to parse their own options.
_n=$#; _i=0
while [ "$_i" -lt "$_n" ]; do
    _a="$1"; shift
    case "$_a" in
        -v|--verbose) VERBOSE=1; export PLYM_VERBOSE=1 ;;
        *) set -- "$@" "$_a" ;;
    esac
    _i=$((_i + 1))
done

case "${1:-}" in
    list) cmd_list ;;
    use) shift; cmd_use "$@" ;;
    set)
        case "${2:-}" in
            url) shift 2; cmd_set_url "$@" ;;
            *)   usage; exit 1 ;;
        esac
        ;;
    unset)
        case "${2:-}" in
            url) shift 2; cmd_unset_url ;;
            *)   usage; exit 1 ;;
        esac
        ;;
    template)
        case "${2:-}" in
            install) shift 2; cmd_template_install "$@" ;;
            *)       usage; exit 1 ;;
        esac
        ;;
    admin)
        case "${2:-}" in
            update) shift 2; cmd_admin_update ;;
            *)      usage; exit 1 ;;
        esac
        ;;
    reload) cmd_reload ;;
    rebuild) cmd_rebuild ;;
    update) cmd_update ;;
    reinstall) shift; cmd_reinstall "$@" ;;
    -h|--help|help|"") usage ;;
    *) usage; exit 1 ;;
esac
