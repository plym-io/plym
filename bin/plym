#!/bin/sh
# plym CLI
#   plym list
#   plym use <name|dir>
#   plym template install <name> [ref]
#   plym rebuild
# Global: -C <dir> / --project <dir> / PLYM_DIR target a specific blog.

set -e

REPO_OWNER="${PLYM_TEMPLATE_REPO_OWNER:-plym-io}"
REPO_NAME="${PLYM_TEMPLATE_REPO_NAME:-plym-templates}"
HEALTH_TIMEOUT_SECONDS="${PLYM_HEALTH_TIMEOUT_SECONDS:-60}"

PLYM_HOME="${PLYM_CONFIG_HOME:-$HOME/.config/plym}"
ACTIVE_FILE="$PLYM_HOME/active"

BOLD=$(printf '\033[1m')
DIM=$(printf '\033[2m')
ACCENT=$(printf '\033[38;5;208m')
GREEN=$(printf '\033[38;5;40m')
RESET=$(printf '\033[0m')

say()  { printf "%s→%s %s\n" "$ACCENT" "$RESET" "$1"; }
note() { printf "%s%s%s\n" "$DIM" "$1" "$RESET"; }
fail() { printf "%s✗%s %s\n" "$ACCENT" "$RESET" "$1" >&2; exit "${2:-1}"; }

[ -e /dev/tty ] && SPIN_OUT=/dev/tty || SPIN_OUT=/dev/stdout
spin() {
    msg="$1"; shift
    log=$(mktemp)
    "$@" >"$log" 2>&1 &
    pid=$!
    while kill -0 "$pid" 2>/dev/null; do
        for frame in ⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏; do
            kill -0 "$pid" 2>/dev/null || break
            printf "\r%s%s%s %s " "$ACCENT" "$frame" "$RESET" "$msg" > "$SPIN_OUT"
            sleep 0.08
        done
    done
    rc=0; wait "$pid" || rc=$?
    if [ "$rc" -eq 0 ]; then
        printf "\r%s✓%s %s\n" "$ACCENT" "$RESET" "$msg" > "$SPIN_OUT"
    else
        printf "\r%s✗%s %s\n" "$ACCENT" "$RESET" "$msg" > "$SPIN_OUT"
        cat "$log" >&2
    fi
    rm -f "$log"
    return "$rc"
}

abspath() {
    if readlink -f "$1" >/dev/null 2>&1; then
        readlink -f "$1"
    else
        python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "$1"
    fi
}

is_plym_dir() {
    [ -f "$1/docker-compose.yml" ] && grep -q 'io\.plym\.instance' "$1/docker-compose.yml" 2>/dev/null
}

instance_port() {
    p=$(grep '^PLYM_PORT=' "$1/.env" 2>/dev/null | cut -d= -f2- | head -1)
    printf '%s' "${p:-9173}"
}

list_instances() {
    docker ps -a --filter label=io.plym.instance \
        --format '{{.Label "com.docker.compose.project.working_dir"}}	{{.Label "com.docker.compose.project"}}	{{.State}}' \
        2>/dev/null | awk 'NF' | sort -u
}

find_project_upward() {
    d=$(pwd)
    while [ "$d" != "/" ]; do
        if is_plym_dir "$d"; then printf '%s\n' "$d"; return 0; fi
        d=$(dirname "$d")
    done
    return 1
}

resolve_project() {
    RESOLVED=""
    if [ -n "$OPT_PROJECT" ]; then
        is_plym_dir "$OPT_PROJECT" || fail "Not a plym project: $OPT_PROJECT"
        RESOLVED=$(abspath "$OPT_PROJECT"); return 0
    fi
    if [ -n "$PLYM_DIR" ]; then
        is_plym_dir "$PLYM_DIR" || fail "PLYM_DIR is not a plym project: $PLYM_DIR"
        RESOLVED=$(abspath "$PLYM_DIR"); return 0
    fi
    if up=$(find_project_upward); then RESOLVED="$up"; return 0; fi
    if [ -f "$ACTIVE_FILE" ]; then
        a=$(cat "$ACTIVE_FILE")
        if is_plym_dir "$a"; then RESOLVED="$a"; return 0; fi
    fi
    dirs=$(list_instances | cut -f1 | awk 'NF')
    count=$(printf '%s\n' "$dirs" | awk 'NF' | wc -l | tr -d ' ')
    if [ "$count" = "1" ]; then RESOLVED="$dirs"; return 0; fi
    [ "$count" = "0" ] && fail "No plym instance found. Run from inside a blog directory, set PLYM_DIR, or pass -C <dir>."
    fail "Multiple blogs and none active. Pick one with 'plym use <name>' (or pass -C <dir>):

$(cmd_list)"
}

enter_project() {
    resolve_project
    cd "$RESOLVED"
    PROJECT_ROOT="$RESOLVED"
    PORT=$(instance_port "$RESOLVED")
    BASE_URL="http://localhost:$PORT"
    PROJECT_LABEL=$(grep '^COMPOSE_PROJECT_NAME=' .env 2>/dev/null | cut -d= -f2- | head -1)
    [ -n "$PROJECT_LABEL" ] || PROJECT_LABEL=$(basename "$PROJECT_ROOT")
}

usage() {
    cat <<EOF
Usage:
  plym list                            Show every blog on this machine (active one in green).
  plym use <name|dir>                  Set the active blog for commands run outside a blog dir.
  plym template install <name> [ref]   Download a template into plym/templates/ and switch to it.
                                       Default ref: main. Refs can be a branch, tag, or commit SHA.
  plym rebuild                         Restart the api and re-render every published post.

Target selection (template/rebuild):
  -C <dir>, --project <dir>            Operate on the blog in <dir>.
  PLYM_DIR=<dir>                       Same, via environment.
  Otherwise: the current blog dir if you are inside one, else the active blog,
  else the sole blog if there is only one.

Environment overrides:
  PLYM_TEMPLATE_REPO_OWNER (default: plym-io)
  PLYM_TEMPLATE_REPO_NAME  (default: plym-templates)
  PLYM_HEALTH_TIMEOUT_SECONDS (default: 60)
EOF
}

wait_for_health() {
    tries=0
    until curl -fsS $BASE_URL/health >/dev/null 2>&1; do
        tries=$((tries + 1))
        if [ "$tries" -gt "$HEALTH_TIMEOUT_SECONDS" ]; then
            fail "API did not come up within ${HEALTH_TIMEOUT_SECONDS}s"
        fi
        sleep 1
    done
}

load_creds() {
    [ -f .env ] || fail ".env not found in $PROJECT_ROOT"
    EMAIL=$(grep '^PLYM_SUPERUSER_EMAIL=' .env | cut -d= -f2- | head -1)
    PASSWORD=$(grep '^PLYM_SUPERUSER_PASSWORD=' .env | cut -d= -f2- | head -1)
    [ -n "$EMAIL" ] && [ -n "$PASSWORD" ] || \
        fail "Could not read PLYM_SUPERUSER_EMAIL/PASSWORD from .env"
}

login() {
    load_creds
    TOKEN=$(curl -fsS -X POST $BASE_URL/api/auth/login \
        -H 'Content-Type: application/json' \
        -d "{\"email\":\"$EMAIL\",\"password\":\"$PASSWORD\"}" \
        | grep -o '"access_token":"[^"]*"' | sed 's/^"access_token":"//;s/"$//')
    [ -n "$TOKEN" ] || fail "Login failed for $EMAIL"
}

refresh_all_posts() {
    login
    ids=$(curl -fsS "$BASE_URL/api/posts?include_drafts=true&page_size=200" \
            -H "Authorization: Bearer $TOKEN" \
            | python3 -c "import sys,json;print(' '.join(str(p['id']) for p in json.load(sys.stdin)['items']))")
    [ -n "$ids" ] || return 0
    for id in $ids; do
        curl -fsS -o /dev/null -X POST "$BASE_URL/api/posts/$id/refresh" \
             -H "Authorization: Bearer $TOKEN"
    done
}

restart_api() {
    docker compose restart api >/dev/null
    wait_for_health
}

install_template() {
    name="$1"; ref="$2"
    target="plym/templates/$name"
    tmp=$(mktemp -d)
    url="https://codeload.github.com/$REPO_OWNER/$REPO_NAME/tar.gz/$ref"
    if ! curl -fsSL "$url" \
        | tar -xz -C "$tmp" --strip-components=1 "$REPO_NAME-$ref/$name" 2>/dev/null \
        || [ ! -d "$tmp/$name" ]; then
        rm -rf "$tmp"
        echo "Template '$name' not found in $REPO_OWNER/$REPO_NAME@$ref" >&2
        return 1
    fi
    rm -rf "$target"
    mv "$tmp/$name" "$target"
    rm -rf "$tmp"
    if grep -q '^template:' config.yaml; then
        sed -i.bak "s|^template: .*|template: $name|" config.yaml
        rm -f config.yaml.bak
    else
        printf "template: %s\n" "$name" >> config.yaml
    fi
}

cmd_list() {
    active=""
    [ -f "$ACTIVE_FILE" ] && active=$(cat "$ACTIVE_FILE")
    rows=$(list_instances)
    if [ -z "$rows" ]; then
        note "No plym blogs found."
        return
    fi
    printf "%s%-16s %-6s %-9s %s%s\n" "$DIM" "NAME" "PORT" "STATUS" "DIR" "$RESET"
    printf '%s\n' "$rows" | while IFS='	' read -r dir project state; do
        [ -n "$dir" ] || continue
        field=$(printf '%-16s' "$project")
        [ "$dir" = "$active" ] && field="${GREEN}${field}${RESET}"
        printf "%s %-6s %-9s %s\n" "$field" "$(instance_port "$dir")" "$state" "$dir"
    done
}

cmd_use() {
    target="$1"
    [ -n "$target" ] || { usage; exit 1; }
    match=""
    rows=$(list_instances)
    if [ -n "$rows" ]; then
        match=$(printf '%s\n' "$rows" | while IFS='	' read -r dir project state; do
            [ -n "$dir" ] || continue
            if [ "$project" = "$target" ] || [ "$dir" = "$target" ] || [ "$(basename "$dir")" = "$target" ]; then
                printf '%s\n' "$dir"; break
            fi
        done)
    fi
    if [ -z "$match" ] && is_plym_dir "$target"; then
        match=$(abspath "$target")
    fi
    [ -n "$match" ] || fail "No plym blog matching '$target'. See 'plym list'."
    mkdir -p "$PLYM_HOME"
    printf '%s\n' "$match" > "$ACTIVE_FILE"
    printf "%s→%s %s%s%s now active %s(:%s)%s\n" \
        "$ACCENT" "$RESET" "$GREEN" "$(basename "$match")" "$RESET" \
        "$DIM" "$(instance_port "$match")" "$RESET"
}

cmd_template_install() {
    enter_project
    name="$1"
    ref="${2:-main}"
    [ -n "$name" ] || { usage; exit 1; }

    note "Installing template '$name' into $PROJECT_LABEL"
    spin "Downloading $name from $REPO_OWNER/$REPO_NAME@$ref" install_template "$name" "$ref"
    spin "Restarting api" restart_api
    spin "Re-rendering published posts" refresh_all_posts
    say "Template '$name' is live."
}

cmd_rebuild() {
    enter_project
    note "Rebuilding $PROJECT_LABEL (:$PORT)"
    spin "Restarting api" restart_api
    spin "Re-rendering published posts" refresh_all_posts
    say "Rebuild complete."
}

OPT_PROJECT=""
while [ $# -gt 0 ]; do
    case "$1" in
        -C|--project)
            [ -n "$2" ] || fail "$1 requires a directory"
            OPT_PROJECT="$2"; shift 2 ;;
        --) shift; break ;;
        *) break ;;
    esac
done

case "${1:-}" in
    list) cmd_list ;;
    use) shift; cmd_use "$@" ;;
    template)
        case "${2:-}" in
            install) shift 2; cmd_template_install "$@" ;;
            *)       usage; exit 1 ;;
        esac
        ;;
    rebuild) cmd_rebuild ;;
    -h|--help|help|"") usage ;;
    *) usage; exit 1 ;;
esac
