:80 {
	encode zstd gzip

	@backend path /api/* /docs /docs/* /openapi.json /health /admin /admin/*
	handle @backend {
		reverse_proxy api:8000
	}

	handle /mcp* {
		reverse_proxy mcp:8000
	}

	handle_path {$PLYM_BLOG_PREFIX:/blog}/api/* {
		rewrite * /api{path}
		reverse_proxy api:8000
	}

	handle_path {$PLYM_BLOG_PREFIX:/blog}/webfonts/* {
		root * /srv/storage/webfonts
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle_path {$PLYM_BLOG_PREFIX:/blog}/static/* {
		root * /srv/storage/static
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle_path {$PLYM_BLOG_PREFIX:/blog}/media/* {
		root * /srv/storage/_uploads
		@found file {path}
		handle @found {
			header Cache-Control "public, max-age=31536000"
			file_server
		}
		handle {
			rewrite * {$PLYM_BLOG_PREFIX:/blog}/media{path}
			reverse_proxy api:8000
		}
	}

	handle /webfonts/* {
		root * /srv/storage
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle /static/* {
		root * /srv/storage
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle /media/* {
		uri replace /media/ /_uploads/
		root * /srv/storage
		@found file {path}
		handle @found {
			header Cache-Control "public, max-age=31536000"
			file_server
		}
		handle {
			uri replace /_uploads/ /media/
			reverse_proxy api:8000
		}
	}

	handle_path {$PLYM_BLOG_PREFIX:/blog}/* {
		root * /srv/storage/.generated

		@md {
			header Accept *text/markdown*
			file {path}.md
		}
		handle @md {
			rewrite * {path}.md
			header Content-Type "text/markdown; charset=utf-8"
			header Cache-Control "public, max-age=300"
			header Vary "Accept"
			file_server
		}

		@mdfile {
			path_regexp mdslug ^/(?P<base>[a-z0-9-]+)\.md$
			file {path}
		}
		handle @mdfile {
			header Content-Type "text/markdown; charset=utf-8"
			header Cache-Control "public, max-age=300"
			header Link `<https://{host}{$PLYM_BLOG_PREFIX:/blog}/{re.mdslug.base}>; rel="canonical"`
			file_server
		}

		@page file {path}.html
		handle @page {
			rewrite * {path}.html
			header Cache-Control "public, max-age=300, stale-while-revalidate=60"
			header Vary "Accept"
			file_server
		}
		handle {
			rewrite * {$PLYM_BLOG_PREFIX:/blog}{path}
			reverse_proxy api:8000
		}
	}

	handle {
		reverse_proxy api:8000
	}
}
