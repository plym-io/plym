PLYM_DEBUG=true
PLYM_PORT=9173
PLYM_BLOG_PREFIX=/blog

PLYM_DB_HOST=db
PLYM_DB_PORT=5432
PLYM_DB_NAME=plym
PLYM_DB_USER=plym
PLYM_DB_PASSWORD=plym

PLYM_SUPERUSER_EMAIL=root@plym.local
PLYM_SUPERUSER_PASSWORD=plym

PLYM_JWT_SECRET=random-secret
PLYM_JWT_ACCESS_TTL_SECONDS=900
PLYM_JWT_REFRESH_TTL_SECONDS=2592000

PLYM_UPLOAD_MAX_BYTES=10485760
PLYM_CONFIG_PATH=/app/config.yaml

PLYM_ADMIN_VERSION=v1.0.0

# MCP server (off by default). Managed by `plym enable mcp <url> --<proxy>`.
# PLYM_MCP_PUBLISH_PORT=9369

# Pin the plym image to a specific tag from hub.docker.com/r/plymio/plym.
# PLYM_IMAGE=plymio/plym:latest
